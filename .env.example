# Postgres connection. For local dev with docker-compose use the value below.
# In production (dokploy) point this at your managed Postgres.
DATABASE_URL=postgresql://longear:longear-dev-password@localhost:5432/longear?schema=public

# Admin panel super-user credentials. Change these in production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# Session signing secret. MUST be at least 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Cloudflare R2 (S3-compatible) credentials for volunteer avatar uploads.
# Get these from the Cloudflare dashboard → R2 → "Manage R2 API Tokens".
# Endpoint is derived automatically from ACCOUNT_ID.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=longear-uploads
# Public base URL for the bucket. Either the auto pub-XXX.r2.dev URL
# (after enabling "Public Access") or your custom domain. No trailing slash.
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
