generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Volunteer {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  bio       String
  avatarKey String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("volunteers")
}

model Animal {
  id                 String   @id
  caption            String
  scientificName     String   @map("scientific_name")
  description        String
  habitat            String
  conservationStatus String   @map("conservation_status")
  origin             String
  populationNote     String   @map("population_note")
  imageKey           String?  @map("image_key")
  lat                Float
  lng                Float
  objectPosition     String   @default("50% 50%") @map("object_position")
  rotate             Int      @default(0)
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([sortOrder])
  @@map("animals")
}
